PORT=5000
NODE_ENV=development

# Encode special characters in your MongoDB password before using this URI.
# Example password my@pass#123 becomes my%40pass%23123
MONGO_URI=mongodb+srv://username:encodedPassword@cluster.mongodb.net/dbname?retryWrites=true&w=majority

FRONTEND_URL=http://localhost:5173

JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d

# SMTP is optional for Render startup. OTP email APIs return 503 if these are missing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM=Auth App <your_email@gmail.com>

OTP_EXPIRES_IN_MINUTES=10

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
